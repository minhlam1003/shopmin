{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the inventory",
      "type": "object",
      "properties": {
        "type": { "type": "string", "description": "Loại hàng" },
        "category": { "type": "string", "description": "Nhóm hàng" },
        "code": { "type": "string", "description": "Mã hàng" },
        "name": { "type": "string", "description": "Tên hàng" },
        "brand": { "type": "string", "description": "Thương hiệu" },
        "sellPrice": { "type": "number", "description": "Giá bán" },
        "buyPrice": { "type": "number", "description": "Giá vốn" },
        "stockLevel": { "type": "number", "description": "Tồn kho" },
        "minStock": { "type": "number", "description": "Tồn nhỏ nhất" },
        "maxStock": { "type": "number", "description": "Tồn lớn nhất" },
        "unit": { "type": "string", "description": "ĐVT" },
        "images": { "type": "string", "description": "Hình ảnh (url)" },
        "weight": { "type": "number", "description": "Trọng lượng" },
        "isDirectlySold": { "type": "boolean", "description": "Được bán trực tiếp" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "category", "code", "name", "sellPrice", "buyPrice", "stockLevel", "unit"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer of the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer name" },
        "phone": { "type": "string", "description": "Phone number" },
        "address": { "type": "string", "description": "Địa chỉ" },
        "currentDebt": { "type": "number", "description": "Outstanding debt amount" }
      },
      "required": ["name", "currentDebt"]
    },
    "Order": {
      "title": "Order",
      "description": "A sales order",
      "type": "object",
      "properties": {
        "orderCode": { "type": "string", "description": "Mã đơn" },
        "customerId": { "type": "string", "description": "ID of the customer" },
        "customerName": { "type": "string", "description": "Name of the customer for quick display" },
        "totalAmount": { "type": "number", "description": "Total order value" },
        "status": { "type": "string", "enum": ["paid", "debt"], "description": "Payment status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order timestamp" }
      },
      "required": ["orderCode", "customerId", "totalAmount", "status", "createdAt"]
    },
    "OrderDetail": {
      "title": "OrderDetail",
      "description": "An item within an order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string", "description": "ID of the parent order" },
        "productId": { "type": "string", "description": "ID of the product" },
        "productName": { "type": "string", "description": "Name of the product" },
        "quantity": { "type": "number", "description": "Quantity purchased" },
        "unitPrice": { "type": "number", "description": "Price per unit at time of sale" },
        "subtotal": { "type": "number", "description": "quantity * unitPrice" }
      },
      "required": ["orderId", "productId", "quantity", "unitPrice", "subtotal"]
    },
    "StoreSettings": {
      "title": "StoreSettings",
      "description": "Configuration settings for the store",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "website": { "type": "string" },
        "logoUrl": { "type": "string" },
        "invoiceHeader": { "type": "string" },
        "invoiceFooter": { "type": "string" },
        "adminName": { "type": "string" },
        "adminEmail": { "type": "string" },
        "bankName": { "type": "string" },
        "bankAccount": { "type": "string" },
        "bankOwner": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AppUser": {
      "title": "AppUser",
      "description": "A user of the application with specific roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Collection of customers"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/orders/{orderId}/details/{detailId}": {
      "schema": "OrderDetail",
      "description": "Sub-collection of order details"
    },
    "/settings/{configId}": {
      "schema": "StoreSettings",
      "description": "Store configuration settings"
    },
    "/users/{userId}": {
      "schema": "AppUser",
      "description": "Application users and their roles"
    }
  }
}
